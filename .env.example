# =============================================================================
# SWAFI - Sistema Web de Gestión de Facturas de Activo Fijo
# Plantilla de variables de entorno
# =============================================================================
#
# Este archivo NO debe contener contraseñas, llaves privadas ni credenciales
# reales. Copia esta plantilla como .env y configura los secretos directamente
# en el entorno local o en Laravel Cloud.
#
# Recomendaciones para producción:
# - APP_ENV=production
# - APP_DEBUG=false
# - APP_URL con HTTPS
# - SESSION_SECURE_COOKIE=true
# - SWAFI_STORAGE_DISK=s3 con bucket privado
# - MAIL_MAILER=smtp o un transporte real equivalente
# - RECAPTCHA_SITE_KEY y RECAPTCHA_SECRET_KEY configuradas
#

# =============================================================================
# APLICACIÓN
# =============================================================================
APP_NAME="SWAFI Bimbo"
APP_ENV=production
APP_KEY=
APP_PREVIOUS_KEYS=
APP_DEBUG=false
APP_URL=https://swafi.example.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

# En despliegues con más de una instancia se recomienda el driver "cache".
APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=database

# Solo para desarrollo con el servidor integrado de PHP.
# PHP_CLI_SERVER_WORKERS=4

# Costo de bcrypt utilizado por Laravel.
BCRYPT_ROUNDS=12

# =============================================================================
# AUTENTICACIÓN Y RECUPERACIÓN DE CONTRASEÑA
# =============================================================================
AUTH_GUARD=web
AUTH_PASSWORD_BROKER=users
AUTH_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens
AUTH_PASSWORD_TIMEOUT=10800

# =============================================================================
# REGISTRO DE EVENTOS Y ERRORES
# =============================================================================
# En Laravel Cloud se recomienda enviar la salida a stderr.
LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false
LOG_LEVEL=info
LOG_DAILY_DAYS=14

# Integraciones opcionales de monitoreo.
# LOG_SLACK_WEBHOOK_URL=
# LOG_SLACK_USERNAME="SWAFI"
# LOG_SLACK_EMOJI=:warning:
# PAPERTRAIL_URL=
# PAPERTRAIL_PORT=

# =============================================================================
# BASE DE DATOS MYSQL
# =============================================================================
DB_CONNECTION=mysql

# Laravel Cloud puede inyectar DB_URL. Si se utiliza, puede sustituir los
# parámetros individuales DB_HOST, DB_PORT, DB_DATABASE, DB_USERNAME y
# DB_PASSWORD.
# DB_URL=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=swafi
DB_USERNAME=swafi
DB_PASSWORD=
DB_SOCKET=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Certificado CA opcional cuando el servidor MySQL exige TLS explícito.
# MYSQL_ATTR_SSL_CA=/ruta/segura/ca.pem

# =============================================================================
# CACHÉ
# =============================================================================
CACHE_STORE=database
CACHE_PREFIX=swafi_cache_
DB_CACHE_CONNECTION=mysql
DB_CACHE_TABLE=cache
DB_CACHE_LOCK_CONNECTION=mysql
DB_CACHE_LOCK_TABLE=cache_locks

# =============================================================================
# COLAS Y TRABAJOS ASÍNCRONOS
# =============================================================================
# SWAFI utiliza la conexión de base de datos y la cola "reports" para los
# reportes programados. El worker de producción debe escuchar, por lo menos,
# las colas "default,reports".
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
DB_QUEUE_CONNECTION=mysql
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=300

# =============================================================================
# SESIONES SEGURAS
# =============================================================================
SESSION_DRIVER=database
SESSION_CONNECTION=mysql
SESSION_TABLE=sessions
SESSION_LIFETIME=10
SESSION_EXPIRE_ON_CLOSE=true
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_PARTITIONED_COOKIE=false

# Límites adicionales de sesión implementados por SWAFI.
# 600 segundos = 10 minutos de inactividad.
# 28800 segundos = 8 horas de duración absoluta.
SWAFI_SESSION_INACTIVITY_SECONDS=600
SWAFI_SESSION_ABSOLUTE_SECONDS=28800
SWAFI_SESSION_WARNING_SECONDS=60
SWAFI_SESSION_HEARTBEAT_SECONDS=60

# =============================================================================
# ALMACENAMIENTO DOCUMENTAL
# =============================================================================
# Producción: utilizar "s3" con bucket privado.
# Desarrollo local: cambiar FILESYSTEM_DISK y SWAFI_STORAGE_DISK a "local".
FILESYSTEM_DISK=s3
SWAFI_STORAGE_DISK=s3

# Disco donde se encuentran archivos históricos creados antes de utilizar S3.
SWAFI_LEGACY_STORAGE_DISK=local

# Debe permanecer en false en producción. Solo habilitar temporalmente en un
# entorno controlado cuando se haya evaluado el riesgo de pérdida de archivos.
SWAFI_ALLOW_LOCAL_IN_PRODUCTION=false

# Auditoría programada de avatares, PDF, XML y evidencias mediante hash SHA-256.
SWAFI_STORAGE_AUDIT_SCHEDULED=true
# La aplicación trabaja en UTC; esta hora se interpreta en UTC.
SWAFI_STORAGE_AUDIT_TIME=02:30

# Credenciales de Object Storage S3 o compatible con S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# CORREO ELECTRÓNICO
# =============================================================================
# Los reportes programados y los recordatorios requieren un transporte real.
# No utilizar MAIL_MAILER=log en producción para esas funcionalidades.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_EHLO_DOMAIN=swafi.example.com
MAIL_FROM_ADDRESS=no-reply@swafi.example.com
MAIL_FROM_NAME="${APP_NAME}"

# Alternativa: configurar la conexión SMTP completa en una sola URL.
# MAIL_URL=

# Proveedores opcionales soportados por la configuración de Laravel.
# POSTMARK_API_KEY=
# POSTMARK_MESSAGE_STREAM_ID=
# RESEND_API_KEY=

# =============================================================================
# GOOGLE reCAPTCHA v3
# =============================================================================
# Obligatorio para inicio de sesión, solicitud de recuperación y restablecimiento
# de contraseña. Las claves deben corresponder al dominio definido en APP_URL.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# =============================================================================
# REPORTES PROGRAMADOS - HU-082
# =============================================================================
SWAFI_SCHEDULED_REPORTS_ENABLED=true
SWAFI_SCHEDULED_REPORTS_TIMEZONE=America/Mexico_City
SWAFI_SCHEDULED_REPORTS_QUEUE=reports
SWAFI_SCHEDULED_REPORTS_BATCH_LIMIT=50

# Lista separada por comas. Solo estos dominios podrán recibir reportes.
SWAFI_SCHEDULED_REPORTS_ALLOWED_DOMAINS=bimbo.local,grupobimbo.com

# =============================================================================
# SEGUIMIENTO DE OBSERVACIONES - HU-014
# =============================================================================
SWAFI_OBSERVATION_REMINDERS_ENABLED=true
SWAFI_OBSERVATION_REMINDERS_TIMEZONE=America/Mexico_City
SWAFI_OBSERVATION_REMINDERS_TIME=08:00
SWAFI_OBSERVATION_DUE_SOON_DAYS=2
SWAFI_OBSERVATION_REMINDERS_BATCH_LIMIT=50

# =============================================================================
# REGISTRO MASIVO, CATÁLOGOS Y BITÁCORA
# =============================================================================
# Ventana de reversión controlada: de 1 a 168 horas.
SWAFI_IMPORT_ROLLBACK_HOURS=24

# Carga inicial de catálogos: de 1 a 20000 filas.
SWAFI_CATALOG_IMPORT_MAX_ROWS=5000

# Vigencia de una previsualización de catálogos: de 1 a 72 horas.
SWAFI_CATALOG_IMPORT_PREVIEW_HOURS=24

# Máximo de eventos por exportación de bitácora: de 100 a 50000 filas.
SWAFI_AUDIT_EXPORT_LIMIT=10000

# =============================================================================
# CABECERAS DE SEGURIDAD Y CSP
# =============================================================================
SWAFI_CSP_ENABLED=true

# false: la política se aplica y bloquea contenido no autorizado.
# true: solo genera reportes y no bloquea; utilizar únicamente para diagnóstico.
SWAFI_CSP_REPORT_ONLY=false

# =============================================================================
# APROVISIONAMIENTO TEMPORAL DEL PRIMER ADMINISTRADOR SWAFI
# =============================================================================
# Estas variables deben permanecer vacías normalmente. Configúralas únicamente
# al ejecutar el comando seguro de aprovisionamiento o rotación. Después de usar
# SWAFI_BOOTSTRAP_ADMIN_PASSWORD, elimínala del entorno y limpia la caché.
SWAFI_BOOTSTRAP_ADMIN_NAME=
SWAFI_BOOTSTRAP_ADMIN_EMAIL=
SWAFI_BOOTSTRAP_ADMIN_USER=
SWAFI_BOOTSTRAP_ADMIN_PASSWORD=

# =============================================================================
# REDIS OPCIONAL
# =============================================================================
# Puede utilizarse en el futuro para caché, sesiones o colas distribuidas.
# Para habilitarlo, cambia CACHE_STORE, SESSION_DRIVER o QUEUE_CONNECTION según
# corresponda y configura las variables siguientes.
REDIS_CLIENT=phpredis
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=300
REDIS_PREFIX=swafi_database_
REDIS_PERSISTENT=false
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000

# =============================================================================
# FRONTEND
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
